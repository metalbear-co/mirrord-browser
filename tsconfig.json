{
    "compilerOptions": {
        "target": "ES6",
        "lib": ["dom", "es6", "ES2015"],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "noEmit": true,
        "allowImportingTsExtensions": true,
        "jsx": "react-jsx"
    },
    "include": [
        "packages/core/src",
        "e2e",
        "playwright.config.ts",
        "jest.setup.ts"
    ]
}
