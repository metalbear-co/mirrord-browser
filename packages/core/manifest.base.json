{
    "manifest_version": 3,
    "name": "mirrord",
    "version": "0.3.1",
    "description": "More user-friendly testing with mirrord by automatically injecting HTTP header",
    "icons": {
        "48": "images/mirrord.png"
    },
    "permissions": ["declarativeNetRequest", "storage", "webRequest"],
    "host_permissions": ["<all_urls>"],
    "options_page": "pages/options.html",
    "content_scripts": [
        {
            "matches": [
                "https://metalbear.com/mirrord/extension*",
                "https://www.metalbear.com/mirrord/extension*"
            ],
            "js": ["src/content/metalbearConfig.ts"],
            "run_at": "document_idle"
        }
    ]
}
